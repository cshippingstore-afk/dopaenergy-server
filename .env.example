# DOPAENERGY Game Server — Environment Variables

# Server
PORT=2567
HOST=0.0.0.0
NODE_ENV=development

# Solana RPC (use Helius or QuickNode for production)
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# DOPA Token mint address (replace at launch)
DOPA_MINT_ADDRESS=DoPA1iquidityArena2025xSoLaNaMaiNnEt3Token

# Escrow wallet (server-side keypair for holding entry fees)
# ESCROW_PRIVATE_KEY=base58_encoded_private_key

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5500,https://dopaenergy.com
